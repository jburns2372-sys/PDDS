
{
  "entities": {
    "user": {
      "title": "User",
      "description": "A user of the application.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "fullName": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "streetAddress": { "type": "string" },
        "barangay": { "type": "string" },
        "city": { "type": "string" },
        "province": { "type": "string" },
        "islandGroup": { 
          "type": "string", 
          "enum": ["Luzon", "Visayas", "Mindanao"],
          "description": "Auto-tagged regional grouping."
        },
        "zipCode": { "type": "string" },
        "role": {
          "type": "string",
          "enum": [
            "President", "Chairman", "Vice Chairman", "VP", "Secretary General",
            "Treasurer", "Auditor", "VP Ways & Means Chair", "VP Media Comms",
            "VP Soc Med Comms", "VP Events and Programs", "VP Membership",
            "VP legal affairs", "Officer", "Member", "Admin", "System Admin", 
            "Supporter", "Volunteer", "Coordinator", "Moderator", "Public Relations Officer"
          ]
        },
        "isAdmin": { "type": "boolean", "default": false },
        "isSuperAdmin": { "type": "boolean" },
        "isVerified": { "type": "boolean", "default": false },
        "vettingLevel": {
          "type": "string",
          "enum": ["Bronze", "Silver", "Gold"],
          "description": "Official administrative vetting tier."
        },
        "idVerificationUrl": { "type": "string", "description": "Secure link to government ID scan." },
        "verifiedAt": { "type": "string", "format": "date-time" },
        "verifiedBy": { "type": "string" },
        "jurisdictionLevel": {
          "type": "string",
          "enum": ["National", "Regional", "Provincial", "City/Municipal", "Barangay"]
        },
        "assignedLocation": { "type": "string" },
        "photoURL": { "type": "string" },
        "kartilyaAgreed": { "type": "boolean" },
        "isApproved": { "type": "boolean" },
        "meritPoints": { "type": "number", "default": 0 },
        "referralCount": { "type": "number", "default": 0 },
        "referredBy": { "type": "string" },
        "fcmToken": { "type": "string" },
        "adminNotes": { "type": "string", "description": "Internal administrative notes for leadership only." },
        "createdAt": { "type": "string", "format": "date-time" },
        "lastActive": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "fullName", "role", "jurisdictionLevel", "kartilyaAgreed"]
    },
    "poll": {
      "title": "Referendum Poll",
      "description": "An official party ballot question.",
      "type": "object",
      "properties": {
        "question": { "type": "string" },
        "options": { "type": "array", "items": { "type": "string" } },
        "targetGroup": { "type": "string", "description": "National or City name." },
        "targetRole": { "type": "string" },
        "votes": { "type": "object", "description": "Map of option string to integer count." },
        "votedBy": { "type": "array", "items": { "type": "string" }, "description": "List of UIDs who voted." },
        "isActive": { "type": "boolean" },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["question", "options", "votes", "votedBy", "isActive"]
    },
    "calendar_activity": {
      "title": "Official Calendar Activity",
      "description": "A high-level party directive or mobilization event.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "startDate": { "type": "string", "format": "date-time" },
        "scope": { "type": "string", "enum": ["National", "Regional"] },
        "targetCity": { "type": "string" },
        "targetProvince": { "type": "string" },
        "locationAddress": { "type": "string" },
        "locationCoords": {
          "type": "object",
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" }
          }
        },
        "isAuthorized": { "type": "boolean" },
        "authorizedBy": { "type": "string" },
        "organizerName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "startDate", "scope"]
    },
    "policy": {
      "title": "Policy Manifesto",
      "description": "An official party position or manifesto document.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "category": { "type": "string", "enum": ["Economy", "Justice", "Local Governance", "Security", "Social Welfare", "Education"] },
        "summary": { "type": "string" },
        "documentUrl": { "type": "string" },
        "shareCount": { "type": "number", "default": 0 },
        "quiz": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "question": { "type": "string" },
              "options": { "type": "array", "items": { "type": "string" } },
              "correctAnswerIndex": { "type": "number" }
            }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "category", "summary", "documentUrl"]
    },
    "chat_room": {
      "title": "Chat Room",
      "description": "A jurisdictional conversation hub.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "city": { "type": "string" },
        "isNational": { "type": "boolean" },
        "lastMessage": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name"]
    },
    "chat_message": {
      "title": "Chat Message",
      "description": "An individual message in a town square.",
      "type": "object",
      "properties": {
        "text": { "type": "string" },
        "senderUid": { "type": "string" },
        "senderName": { "type": "string" },
        "senderRole": { "type": "string" },
        "senderVetting": { "type": "string" },
        "senderPhoto": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "isReported": { "type": "boolean" }
      },
      "required": ["text", "senderUid", "senderName", "timestamp"]
    },
    "meeting_request": {
      "title": "Meeting Request",
      "description": "A supporter-led gathering proposal.",
      "type": "object",
      "properties": {
        "hostUid": { "type": "string" },
        "hostName": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "meetingType": { "type": "string", "enum": ["Kapihan", "Study Group", "Rally", "Community Service"] },
        "city": { "type": "string" },
        "province": { "type": "string" },
        "locationAddress": { "type": "string" },
        "locationCoords": { "type": "object" },
        "dateTime": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["Pending", "Approved", "Rejected"] },
        "rejectionReason": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["hostUid", "title", "meetingType", "city", "dateTime"]
    }
  },
  "auth": {
    "providers": ["email-password", "phone", "google.com"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/backend/entities/user" },
      "description": "Stores user profile information."
    },
    "/policies/{policyId}": {
      "schema": { "$ref": "#/backend/entities/policy" },
      "description": "Stores official party policies and manifestos."
    },
    "/chat_rooms/{roomId}": {
      "schema": { "$ref": "#/backend/entities/chat_room" },
      "description": "Stores chat room metadata."
    },
    "/chat_rooms/{roomId}/messages/{messageId}": {
      "schema": { "$ref": "#/backend/entities/chat_message" },
      "description": "Stores individual messages within a room."
    },
    "/meeting_requests/{requestId}": {
      "schema": { "$ref": "#/backend/entities/meeting_request" },
      "description": "Stores supporter-led meeting proposals."
    },
    "/calendar_activities/{activityId}": {
      "schema": { "$ref": "#/backend/entities/calendar_activity" },
      "description": "Stores official party calendar events."
    },
    "/polls/{pollId}": {
      "schema": { "$ref": "#/backend/entities/poll" },
      "description": "Stores official party referendums and sentiment ballots."
    }
  }
}
