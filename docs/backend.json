
{
  "entities": {
    "user": {
      "title": "User",
      "description": "A user of the application.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "fullName": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "streetAddress": { "type": "string" },
        "barangay": { "type": "string" },
        "city": { "type": "string" },
        "province": { "type": "string" },
        "islandGroup": { 
          "type": "string", 
          "enum": ["Luzon", "Visayas", "Mindanao"],
          "description": "Auto-tagged regional grouping."
        },
        "zipCode": { "type": "string" },
        "role": {
          "type": "string",
          "enum": [
            "President", "Chairman", "Vice Chairman", "VP", "Secretary General",
            "Treasurer", "Auditor", "VP Ways & Means Chair", "VP Media Comms",
            "VP Soc Med Comms", "VP Events and Programs", "VP Membership",
            "VP legal affairs", "Officer", "Member", "Admin", "System Admin", 
            "Supporter", "Volunteer", "Coordinator", "Moderator", "Public Relations Officer"
          ]
        },
        "isAdmin": { "type": "boolean", "default": false },
        "isSuperAdmin": { "type": "boolean" },
        "isVerified": { "type": "boolean", "default": false },
        "isMuted": { "type": "boolean", "default": false },
        "vettingLevel": {
          "type": "string",
          "enum": ["Bronze", "Silver", "Gold"]
        },
        "meritPoints": { "type": "number", "default": 0 },
        "referralCount": { "type": "number", "default": 0 },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "fullName", "role"]
    },
    "donation": {
      "title": "PatriotPondo Donation",
      "description": "A financial contribution to the movement.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "donorName": { "type": "string" },
        "amount": { "type": "number" },
        "status": { "type": "string", "enum": ["Pending", "Successful", "Failed"] },
        "isAnonymous": { "type": "boolean" },
        "region": { "type": "string" },
        "paymentMethod": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "expense": {
      "title": "Party Expenditure",
      "description": "An official party expense logged by the Treasurer.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "amount": { "type": "number" },
        "category": { "type": "string", "enum": ["Rallies", "Bayanihan Aid", "Admin", "Logistics", "Marketing"] },
        "receiptUrl": { "type": "string" },
        "loggedBy": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "regional_stats": {
      "title": "Regional Financial Stats",
      "description": "Aggregated financial data for map visualization.",
      "type": "object",
      "properties": {
        "regionName": { "type": "string" },
        "totalFunds": { "type": "number", "default": 0 },
        "donorCount": { "type": "number", "default": 0 },
        "lastUpdated": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["email-password", "phone", "google.com"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/backend/entities/user" },
      "description": "Stores user profile information."
    },
    "/donations/{donationId}": {
      "schema": { "$ref": "#/backend/entities/donation" },
      "description": "Stores financial contributions."
    },
    "/expenses/{expenseId}": {
      "schema": { "$ref": "#/backend/entities/expense" },
      "description": "Stores verified party expenditures."
    },
    "/regional_stats/{regionId}": {
      "schema": { "$ref": "#/backend/entities/regional_stats" },
      "description": "Aggregated regional financial metrics."
    }
  }
}
