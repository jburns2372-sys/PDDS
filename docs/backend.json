
{
  "entities": {
    "user": {
      "title": "User",
      "description": "A user of the application.",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The user's unique ID."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address."
        },
        "fullName": {
          "type": "string",
          "description": "The user's full name."
        },
        "phoneNumber": {
          "type": "string",
          "description": "The user's verified phone number."
        },
        "streetAddress": {
          "type": "string",
          "description": "The user's street name, building, or house number."
        },
        "barangay": {
          "type": "string",
          "description": "The user's barangay."
        },
        "city": {
          "type": "string",
          "description": "The user's city or municipality."
        },
        "province": {
          "type": "string",
          "description": "The user's province."
        },
        "zipCode": {
          "type": "string",
          "description": "The user's postal code."
        },
        "role": {
          "type": "string",
          "description": "The user's role in the party.",
          "enum": [
            "President",
            "Chairman",
            "Vice Chairman",
            "VP",
            "Secretary General",
            "Treasurer",
            "Auditor",
            "VP Ways & Means Chair",
            "VP Media Comms",
            "VP Soc Med Comms",
            "VP Events and Programs",
            "VP Membership",
            "VP legal affairs",
            "Member",
            "Admin",
            "System Admin",
            "Supporter"
          ]
        },
        "jurisdictionLevel": {
          "type": "string",
          "description": "The user's jurisdiction level.",
          "enum": [
            "National",
            "Regional",
            "Provincial",
            "City/Municipal",
            "Barangay"
          ]
        },
        "assignedLocation": {
          "type": "string",
          "description": "The name of the user's assigned location."
        },
        "photoURL": {
          "type": "string",
          "description": "The URL of the user's profile picture."
        },
        "resumeURL": {
          "type": "string",
          "description": "The URL of the user's uploaded resume file."
        },
        "resumeText": {
          "type": "string",
          "description": "The text-based content of the user's resume."
        },
        "aboutText": {
          "type": "string",
          "description": "Biographical information about the officer."
        },
        "kartilyaAgreed": {
          "type": "boolean",
          "description": "Whether the user has agreed to the Kartilya."
        },
        "passwordIsTemporary": {
          "type": "boolean",
          "description": "Whether the user needs to change their temporary password."
        },
        "isApproved": {
          "type": "boolean",
          "description": "Whether the user is approved."
        },
        "isVerified": {
          "type": "boolean",
          "description": "Whether the user's supporter account is verified."
        },
        "isEmailVerified": {
          "type": "boolean",
          "description": "Whether the email is verified."
        },
        "isPhoneVerified": {
          "type": "boolean",
          "description": "Whether the phone is verified."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The timestamp when the user document was created."
        }
      },
      "required": ["uid", "email", "fullName", "role", "jurisdictionLevel", "kartilyaAgreed"]
    },
    "campaign_action": {
      "title": "Campaign Action",
      "description": "A petition or community action for supporters.",
      "type": "object",
      "properties": {
        "title": {
          "type": "string",
          "description": "The title of the petition."
        },
        "description": {
          "type": "string",
          "description": "A detailed description of the action."
        },
        "targetSignatures": {
          "type": "number",
          "description": "The goal number of signatures."
        },
        "signedBy": {
          "type": "array",
          "items": { "type": "string" },
          "description": "List of user UIDs who signed the petition."
        }
      },
      "required": ["title", "description", "targetSignatures", "signedBy"]
    },
    "poll": {
      "title": "Poll",
      "description": "A daily pulse survey for members.",
      "type": "object",
      "properties": {
        "question": {
          "type": "string",
          "description": "The poll question."
        },
        "options": {
          "type": "array",
          "items": { "type": "string" },
          "description": "The possible answers."
        },
        "votes": {
          "type": "object",
          "description": "Map of option names to vote counts."
        },
        "votedBy": {
          "type": "array",
          "items": { "type": "string" },
          "description": "List of user UIDs who have already voted."
        },
        "isActive": {
          "type": "boolean",
          "description": "Whether the poll is currently open for voting."
        }
      },
      "required": ["question", "options", "votes", "votedBy", "isActive"]
    }
  },
  "auth": {
    "providers": ["email-password", "phone"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/backend/entities/user" },
      "description": "Stores user profile information."
    },
    "/campaign_actions/{actionId}": {
      "schema": { "$ref": "#/backend/entities/campaign_action" },
      "description": "Stores petitions and supporter campaign actions."
    },
    "/polls/{pollId}": {
      "schema": { "$ref": "#/backend/entities/poll" },
      "description": "Stores party polls and surveys."
    }
  }
}
