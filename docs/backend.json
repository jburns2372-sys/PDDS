
{
  "entities": {
    "user": {
      "title": "User",
      "description": "A user of the application.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "fullName": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "streetAddress": { "type": "string" },
        "barangay": { "type": "string" },
        "city": { "type": "string" },
        "province": { "type": "string" },
        "zipCode": { "type": "string" },
        "role": {
          "type": "string",
          "enum": [
            "President", "Chairman", "Vice Chairman", "VP", "Secretary General",
            "Treasurer", "Auditor", "VP Ways & Means Chair", "VP Media Comms",
            "VP Soc Med Comms", "VP Events and Programs", "VP Membership",
            "VP legal affairs", "Officer", "Member", "Admin", "System Admin", "Supporter"
          ]
        },
        "isSuperAdmin": { "type": "boolean" },
        "jurisdictionLevel": {
          "type": "string",
          "enum": ["National", "Regional", "Provincial", "City/Municipal", "Barangay"]
        },
        "assignedLocation": { "type": "string" },
        "photoURL": { "type": "string" },
        "kartilyaAgreed": { "type": "boolean" },
        "isApproved": { "type": "boolean" },
        "recruitCount": { "type": "number", "default": 0 },
        "referredBy": { "type": "string" },
        "fcmToken": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "fullName", "role", "jurisdictionLevel", "kartilyaAgreed"]
    },
    "campaign_action": {
      "title": "Campaign Action",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "targetSignatures": { "type": "number" },
        "signedBy": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["title", "description", "targetSignatures", "signedBy"]
    },
    "poll": {
      "title": "Poll",
      "type": "object",
      "properties": {
        "question": { "type": "string" },
        "options": { "type": "array", "items": { "type": "string" } },
        "votes": { "type": "object" },
        "votedBy": { "type": "array", "items": { "type": "string" } },
        "isActive": { "type": "boolean" }
      },
      "required": ["question", "options", "votes", "votedBy", "isActive"]
    },
    "community_feedback": {
      "title": "Community Feedback",
      "description": "Suggestions and concerns from supporters.",
      "type": "object",
      "properties": {
        "topic": { "type": "string", "enum": ["Local Infrastructure", "Social Services", "Community Concerns", "Security", "Others"] },
        "message": { "type": "string" },
        "status": { "type": "string", "enum": ["Received", "Under Review", "Addressed"] },
        "submittedBy": { "type": "string" },
        "submitterUid": { "type": "string" },
        "location": { "type": "string" },
        "officialReply": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["topic", "message", "status", "submittedBy", "submitterUid", "location", "timestamp"]
    },
    "announcement": {
      "title": "Announcement",
      "description": "Official party broadcasts and updates.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "message": { "type": "string" },
        "targetGroup": { "type": "string" },
        "documentLink": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "createdBy": { "type": "string" }
      },
      "required": ["title", "message", "targetGroup", "timestamp", "createdBy"]
    },
    "communication_audit": {
      "title": "Communication Audit",
      "description": "Logs for official SMS and push broadcasts.",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["SMS", "Push", "Dual"] },
        "message": { "type": "string" },
        "targetGroup": { "type": "string" },
        "recipientCount": { "type": "number" },
        "status": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "createdBy": { "type": "string" }
      },
      "required": ["type", "message", "targetGroup", "recipientCount", "timestamp", "createdBy"]
    },
    "communication_log": {
      "title": "Communication Log",
      "description": "Logs of direct messages sent to supporters by officers.",
      "type": "object",
      "properties": {
        "officerUid": { "type": "string" },
        "officerName": { "type": "string" },
        "supporterUid": { "type": "string" },
        "supporterName": { "type": "string" },
        "type": { "type": "string", "enum": ["SMS", "CHAT"] },
        "templateUsed": { "type": "string" },
        "messageContent": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["officerUid", "supporterUid", "type", "timestamp"]
    }
  },
  "auth": {
    "providers": ["email-password", "phone", "google.com", "facebook.com"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/backend/entities/user" },
      "description": "Stores user profile information."
    },
    "/campaign_actions/{actionId}": {
      "schema": { "$ref": "#/backend/entities/campaign_action" },
      "description": "Stores petitions and supporter campaign actions."
    },
    "/polls/{pollId}": {
      "schema": { "$ref": "#/backend/entities/poll" },
      "description": "Stores party polls and surveys."
    },
    "/community_feedback/{feedbackId}": {
      "schema": { "$ref": "#/backend/entities/community_feedback" },
      "description": "Stores member feedback and official replies."
    },
    "/announcements/{announcementId}": {
      "schema": { "$ref": "#/backend/entities/announcement" },
      "description": "Stores official party broadcasts."
    },
    "/communication_audit/{auditId}": {
      "schema": { "$ref": "#/backend/entities/communication_audit" },
      "description": "Stores logs of official party communications."
    },
    "/communication_logs/{logId}": {
      "schema": { "$ref": "#/backend/entities/communication_log" },
      "description": "Stores logs of direct communication between officers and supporters."
    }
  }
}
