
{
  "entities": {
    "user": {
      "title": "User",
      "description": "A user of the application.",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The user's unique ID."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address."
        },
        "fullName": {
          "type": "string",
          "description": "The user's full name."
        },
        "phoneNumber": {
          "type": "string",
          "description": "The user's verified phone number."
        },
        "address": {
          "type": "string",
          "description": "The user's street address."
        },
        "city": {
          "type": "string",
          "description": "The user's city."
        },
        "province": {
          "type": "string",
          "description": "The user's province."
        },
        "zipCode": {
          "type": "string",
          "description": "The user's postal code."
        },
        "role": {
          "type": "string",
          "description": "The user's role in the party.",
          "enum": [
            "President",
            "Chairman",
            "Vice Chairman",
            "VP",
            "Secretary General",
            "Treasurer",
            "Auditor",
            "VP Ways & Means Chair",
            "VP Media Comms",
            "VP Soc Med Comms",
            "VP Events and Programs",
            "VP Membership",
            "VP legal affairs",
            "Member",
            "Admin",
            "System Admin",
            "Supporter"
          ]
        },
        "jurisdictionLevel": {
          "type": "string",
          "description": "The user's jurisdiction level.",
          "enum": [
            "National",
            "Regional",
            "Provincial",
            "City/Municipal",
            "Barangay"
          ]
        },
        "assignedLocation": {
          "type": "string",
          "description": "The name of the user's assigned location."
        },
        "photoURL": {
          "type": "string",
          "description": "The URL of the user's profile picture."
        },
        "resumeURL": {
          "type": "string",
          "description": "The URL of the user's uploaded resume file."
        },
        "resumeText": {
          "type": "string",
          "description": "The text-based content of the user's resume."
        },
        "aboutText": {
          "type": "string",
          "description": "Biographical information about the officer."
        },
        "kartilyaAgreed": {
          "type": "boolean",
          "description": "Whether the user has agreed to the Kartilya."
        },
        "passwordIsTemporary": {
          "type": "boolean",
          "description": "Whether the user needs to change their temporary password."
        },
        "isApproved": {
          "type": "boolean",
          "description": "Whether the user is approved."
        },
        "isVerified": {
          "type": "boolean",
          "description": "Whether the user's supporter account is verified."
        },
        "isEmailVerified": {
          "type": "boolean",
          "description": "Whether the email is verified."
        },
        "isPhoneVerified": {
          "type": "boolean",
          "description": "Whether the phone is verified."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The timestamp when the user document was created."
        }
      },
      "required": ["uid", "email", "fullName", "role", "jurisdictionLevel", "kartilyaAgreed"]
    }
  },
  "auth": {
    "providers": ["email-password", "phone"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/backend/entities/user" },
      "description": "Stores user profile information."
    }
  }
}
