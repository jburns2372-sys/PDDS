{
  "entities": {
    "user": {
      "title": "User",
      "description": "A user of the application.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "fullName": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "streetAddress": { "type": "string" },
        "barangay": { "type": "string" },
        "city": { "type": "string" },
        "province": { "type": "string" },
        "zipCode": { "type": "string" },
        "role": {
          "type": "string",
          "enum": [
            "President", "Chairman", "Vice Chairman", "VP", "Secretary General",
            "Treasurer", "Auditor", "VP Ways & Means Chair", "VP Media Comms",
            "VP Soc Med Comms", "VP Events and Programs", "VP Membership",
            "VP legal affairs", "Officer", "Member", "Admin", "System Admin", "Supporter"
          ]
        },
        "isAdmin": { "type": "boolean", "default": false },
        "isSuperAdmin": { "type": "boolean" },
        "jurisdictionLevel": {
          "type": "string",
          "enum": ["National", "Regional", "Provincial", "City/Municipal", "Barangay"]
        },
        "assignedLocation": { "type": "string" },
        "photoURL": { "type": "string" },
        "kartilyaAgreed": { "type": "boolean" },
        "isApproved": { "type": "boolean" },
        "recruitCount": { "type": "number", "default": 0 },
        "referredBy": { "type": "string" },
        "fcmToken": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "fullName", "role", "jurisdictionLevel", "kartilyaAgreed"]
    },
    "attendance_record": {
      "title": "Attendance Record",
      "description": "A check-in record for a specific event.",
      "type": "object",
      "properties": {
        "eventId": { "type": "string" },
        "userId": { "type": "string" },
        "scannedBy": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["eventId", "userId", "scannedBy", "timestamp"]
    },
    "calendar_activity": {
      "title": "Calendar Activity",
      "description": "An official party activity or event.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "startDate": { "type": "string", "format": "date-time" },
        "endDate": { "type": "string", "format": "date-time" },
        "scope": { "type": "string", "enum": ["National", "Regional"] },
        "targetProvince": { "type": "string" },
        "targetCity": { "type": "string" },
        "meetingLink": { "type": "string" },
        "locationAddress": { "type": "string" },
        "organizerName": { "type": "string" },
        "organizerUid": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "startDate", "scope"]
    }
  },
  "auth": {
    "providers": ["email-password", "phone", "google.com"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/backend/entities/user" },
      "description": "Stores user profile information."
    },
    "/attendance/{attendanceId}": {
      "schema": { "$ref": "#/backend/entities/attendance_record" },
      "description": "Stores official event attendance records."
    },
    "/calendar_activities/{activityId}": {
      "schema": { "$ref": "#/backend/entities/calendar_activity" },
      "description": "Stores official party events and activities."
    }
  }
}