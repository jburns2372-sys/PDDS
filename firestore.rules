
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isPrivilegedEmail() {
      let email = request.auth.token.email.lower();
      return email == 'iamgrecobelgica@gmail.com' || 
             email == 'j.burns2372@gmail.com' || 
             email == 'j.burns.2372@gmail.com' ||
             email == 'j.burns372@gmail.com' ||
             email == 'mariashellajoygomez@gmail.com';
    }

    function isAdministrator() {
      if (!isSignedIn()) return false;
      if (isPrivilegedEmail()) return true;
      
      let userPath = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(userPath) && (
        get(userPath).data.role == 'Admin' || 
        get(userPath).data.role == 'System Admin' || 
        get(userPath).data.role == 'President'
      );
    }

    // Rules for 'users' collection
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId) || isAdministrator();
      allow update: if isOwner(userId) || isAdministrator();
      allow delete: if isAdministrator();
    }

    // Rules for campaign actions
    match /campaign_actions/{actionId} {
      allow read: if isSignedIn();
      allow update: if isSignedIn() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['signedBy']);
      allow write: if isAdministrator();
    }

    // Rules for polls
    match /polls/{pollId} {
      allow read: if isSignedIn();
      allow update: if isSignedIn() && 
                    !resource.data.votedBy.contains(request.auth.uid) &&
                    request.resource.data.votedBy.contains(request.auth.uid) &&
                    request.resource.data.votedBy.size() == resource.data.votedBy.size() + 1;
      allow write: if isAdministrator();
    }
  }
}
