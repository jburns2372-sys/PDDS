rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isPrivilegedEmail() {
      return request.auth.token.email == 'iamgrecobelgica@gmail.com' || 
             request.auth.token.email == 'j.burns2372@gmail.com';
    }

    function isAdministrator() {
      if (!isSignedIn()) return false;
      if (isPrivilegedEmail()) return true;
      
      // Simple role check to avoid recursive depth issues
      let userPath = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(userPath) && (
        get(userPath).data.role == 'Admin' || 
        get(userPath).data.role == 'System Admin' || 
        get(userPath).data.role == 'President'
      );
    }

    // Rules for 'users' collection
    match /users/{userId} {
      // Allow any authenticated member to read the directory
      allow read: if isSignedIn();
      // Allow profile creation if it's the owner or a privileged email
      allow create: if isOwner(userId) || isPrivilegedEmail() || isAdministrator();
      // Allow updates if owner or admin
      allow update: if isOwner(userId) || isPrivilegedEmail() || isAdministrator();
      // Only an Admin can delete users
      allow delete: if isAdministrator();
    }

    // Rules for 'chapters' collection
    match /chapters/{chapterId} {
      allow read: if isSignedIn();
      allow create, update: if isAdministrator();
      allow delete: if false; 
    }
  }
}