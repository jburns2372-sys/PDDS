rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isPrivilegedEmail() {
      return request.auth.token.email == 'iamgrecobelgica@gmail.com' || 
             request.auth.token.email == 'j.burns2372@gmail.com';
    }

    function getUserData(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data;
    }
    
    function isAdministrator() {
      if (!isSignedIn()) return false;
      if (isPrivilegedEmail()) return true;
      
      // Attempt to get user role from Firestore
      let userPath = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(userPath) && (
        get(userPath).data.role == 'Admin' || 
        get(userPath).data.role == 'System Admin' || 
        get(userPath).data.role == 'President'
      );
    }

    // Rules for 'users' collection
    match /users/{userId} {
      allow read: if isSignedIn();
      // Allow creation if the user is the owner (bootstrapping) or an admin
      allow create: if isOwner(userId) || isAdministrator();
      // Allow update if the user is the owner or an admin
      allow update: if isOwner(userId) || isAdministrator();
      // Only an Admin can delete users
      allow delete: if isAdministrator();
    }

    // Rules for 'chapters' collection
    match /chapters/{chapterId} {
      allow read: if isSignedIn();
      allow create, update: if isAdministrator();
      allow delete: if false; 
    }
  }
}