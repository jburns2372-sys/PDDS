rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isPrivilegedEmail() {
      let email = request.auth.token.email;
      return email == 'iamgrecobelgica@gmail.com' || 
             email == 'j.burns2372@gmail.com' || 
             email == 'j.burns.2372@gmail.com';
    }

    function isAdministrator() {
      if (!isSignedIn()) return false;
      if (isPrivilegedEmail()) return true;
      
      // Simple role check to allow administrative roles to manage the registry
      let userPath = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(userPath) && (
        get(userPath).data.role == 'Admin' || 
        get(userPath).data.role == 'System Admin' || 
        get(userPath).data.role == 'President'
      );
    }

    // Rules for 'users' collection
    match /users/{userId} {
      // Allow any authenticated member to read the directory
      allow read: if isSignedIn();
      
      // Allow profile creation if it's the owner, a privileged email, or an administrator
      allow create: if isOwner(userId) || isPrivilegedEmail() || isAdministrator();
      
      // Allow updates if owner, a privileged email, or an administrator
      allow update: if isOwner(userId) || isPrivilegedEmail() || isAdministrator();
      
      // Only an Admin can delete users
      allow delete: if isAdministrator();
    }
  }
}