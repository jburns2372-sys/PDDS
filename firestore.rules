
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isExecutive() {
      return isSignedIn() && getUserData().role in ['President', 'Admin', 'Secretary General', 'System Admin', 'Treasurer'];
    }

    function isSecGen() {
      return isSignedIn() && (getUserData().role == 'Secretary General' || getUserData().role == 'Sec Gen' || getUserData().role == 'President' || getUserData().isSuperAdmin == true);
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (request.auth.uid == userId || isSecGen());
    }

    match /metadata/{id} {
      allow read: if isSignedIn();
      allow write: if isExecutive();
    }

    match /donations/{id} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isExecutive() && getUserData().role == 'Treasurer';
    }

    match /expenses/{id} {
      allow read: if isSignedIn();
      allow write: if isExecutive() && getUserData().role == 'Treasurer';
    }

    match /security_logs/{id} {
      allow read, write: if isSecGen();
    }

    match /communication_audit/{id} {
      allow read: if isExecutive();
      allow write: if isExecutive();
    }

    match /announcements/{id} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && getUserData().role in ['Public Relations Officer', 'President', 'Admin'];
    }

    match /civic_reports/{id} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /sos_alerts/{id} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }
    
    match /patriothub_rooms/{roomId}/messages/{msgId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && getUserData().isVerified == true;
      allow delete: if isSignedIn() && (getUserData().role == 'Coordinator' || isExecutive());
    }

    match /patriothub_pins/{id} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && getUserData().role in ['Public Relations Officer', 'President', 'Admin'];
    }
    
    match /vault/{id} {
      allow read: if isSignedIn();
      allow write: if isExecutive();
    }

    match /calendar_activities/{id} {
      allow read: if isSignedIn();
      allow write: if isExecutive();
    }
  }
}
