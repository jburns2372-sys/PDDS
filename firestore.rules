
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ==========================================
    // SECURITY KERNEL HELPERS
    // ==========================================

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasRole(role) {
      return isSignedIn() && getUserData().role == role;
    }

    function isExecutive() {
      if (!isSignedIn()) return false;
      let userData = getUserData();
      return userData.role in ['President', 'Admin', 'System Admin'] || userData.get('isAdmin', false) == true;
    }

    function isSecGen() {
      return hasRole('Secretary General') || isExecutive();
    }

    // ==========================================
    // COLLECTION-SPECIFIC POLICIES
    // ==========================================

    match /users/{userId} {
      allow read: if isSignedIn() && (
        isOwner(userId) || 
        isExecutive() || 
        isSecGen() || 
        (hasRole('Coordinator') && getUserData().city == resource.data.city)
      );
      
      allow create: if isSignedIn();
      
      allow update: if isExecutive() || (
        isSecGen() && 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isVerified', 'vettingLevel', 'verifiedAt', 'verifiedBy', 'adminNotes', 'isMuted'])
      ) || (
        isOwner(userId) && 
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'isApproved', 'isVerified', 'vettingLevel', 'meritPoints', 'isAdmin', 'isSuperAdmin', 'idVerificationUrl'])
      );
      
      allow delete: if isExecutive();
    }

    match /chat_rooms/{roomId} {
      allow read: if isSignedIn();
      
      match /messages/{msgId} {
        allow read: if isSignedIn();
        
        // Participation Gate: Must be verified AND not muted to speak
        // Also restricts members to their own city room (or National)
        allow create: if isSignedIn() && 
          getUserData().isVerified == true && 
          getUserData().get('isMuted', false) == false &&
          (roomId == 'National' || getUserData().city == roomId) &&
          request.resource.data.senderUid == request.auth.uid;

        // Moderation: Executive or Regional Coordinator
        allow delete: if isExecutive() || (hasRole('Coordinator') && getUserData().city == roomId);
        
        // Safety Reporting
        allow update: if isSignedIn() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isReported']);
      }
    }

    // [Other collections OMITTED for brevity but preserved in database]
    match /policies/{id} { allow read: if isSignedIn(); }
    match /polls/{id} { allow read: if isSignedIn(); }
    match /calendar_activities/{id} { allow read: if isSignedIn(); }
    match /meeting_requests/{id} { allow read: if isSignedIn(); }
  }
}
