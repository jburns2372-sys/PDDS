
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ==========================================
    // SECURITY KERNEL HELPERS
    // ==========================================

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasRole(role) {
      return isSignedIn() && getUserData().role == role;
    }

    function isExecutive() {
      if (!isSignedIn()) return false;
      let userData = getUserData();
      return userData.role in ['President', 'Admin', 'System Admin'] || userData.get('isAdmin', false) == true;
    }

    function isSecGen() {
      return hasRole('Secretary General') || isExecutive();
    }

    function isPRO() {
      return hasRole('Public Relations Officer') || isExecutive();
    }

    function isTreasurer() {
      return hasRole('Treasurer') || isExecutive();
    }

    // ==========================================
    // COLLECTION-SPECIFIC POLICIES
    // ==========================================

    match /users/{userId} {
      // Visibility: Personal profile or Executive/Coordinator oversight
      allow read: if isSignedIn() && (
        isOwner(userId) || 
        isExecutive() || 
        isSecGen() || 
        (hasRole('Coordinator') && getUserData().city == resource.data.city)
      );
      
      allow create: if isSignedIn();
      
      // Update Policy: Owners can edit basic info only. Officers can edit vetting tags.
      allow update: if isExecutive() || (
        isSecGen() && 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isVerified', 'vettingLevel', 'verifiedAt', 'verifiedBy', 'adminNotes'])
      ) || (
        isOwner(userId) && 
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'isApproved', 'isVerified', 'vettingLevel', 'meritPoints', 'isAdmin', 'isSuperAdmin', 'idVerificationUrl'])
      );
      
      allow delete: if isExecutive();

      match /policy_engagement/{id} {
        allow read, write: if isOwner(userId);
      }
    }

    match /policies/{id} {
      allow read: if isSignedIn();
      allow write: if isPRO();
      allow update: if isSignedIn() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['shareCount']);
    }

    match /chat_rooms/{roomId} {
      allow read: if isSignedIn();
      
      match /messages/{msgId} {
        allow read: if isSignedIn();
        
        // Participation Gate: Must be verified to speak
        allow create: if isSignedIn() && 
          getUserData().isVerified == true && 
          (roomId == 'National' || getUserData().city == roomId) &&
          request.resource.data.senderUid == request.auth.uid;

        // Moderation: Executive or Regional Coordinator
        allow delete: if isExecutive() || (hasRole('Coordinator') && getUserData().city == roomId);
        
        // Safety Reporting
        allow update: if isSignedIn() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isReported']);
      }
    }

    match /polls/{id} {
      allow read: if isSignedIn();
      allow create: if isPRO() || isExecutive();
      // One-Member-One-Vote Enforcement
      allow update: if isSignedIn() && 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['votes', 'votedBy']) &&
        !resource.data.votedBy.contains(request.auth.uid) &&
        request.resource.data.votedBy.contains(request.auth.uid);
    }

    match /logistics_logs/{logId} {
      allow read: if isTreasurer() || isExecutive();
      allow write: if isTreasurer() || isExecutive();
    }

    match /calendar_activities/{id} {
      allow read: if isSignedIn() && (resource.data.isAuthorized == true || isExecutive());
      allow create: if isPRO() || isSecGen() || isExecutive();
      allow update, delete: if isExecutive();
    }

    match /meeting_requests/{id} {
      allow read: if isSignedIn() && (
        resource.data.hostUid == request.auth.uid || 
        isExecutive() || 
        (hasRole('Coordinator') && getUserData().city == resource.data.city) ||
        resource.data.status == 'Approved'
      );
      allow create: if isSignedIn() && getUserData().vettingLevel in ['Silver', 'Gold'];
      allow update: if isExecutive() || (hasRole('Coordinator') && getUserData().city == resource.data.city);
    }

    match /vault/{id} {
      allow read: if isSignedIn();
      allow write: if isPRO() || isExecutive();
    }
  }
}
