
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isTreasurer() {
      return isSignedIn() && getUserData().role in ['Treasurer', 'President', 'Admin'];
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (request.auth.uid == userId || getUserData().role in ['Admin', 'President', 'Secretary General']);
    }

    match /donations/{id} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isTreasurer();
    }

    match /expenses/{id} {
      allow read: if isSignedIn();
      allow write: if isTreasurer();
    }

    match /announcements/{id} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && getUserData().role in ['Public Relations Officer', 'President', 'Admin'];
    }

    match /civic_reports/{id} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /sos_alerts/{id} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }
    
    match /chat_rooms/{roomId}/messages/{msgId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && getUserData().isVerified == true;
      allow delete: if isSignedIn() && (getUserData().role == 'Coordinator' || getUserData().role in ['Admin', 'President']);
    }
  }
}
