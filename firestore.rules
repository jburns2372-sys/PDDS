
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ==========================================
    // GLOBAL HELPERS
    // ==========================================

    /**
     * Check if the request is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * Check if the user is accessing their own document.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * Fetches the current user's profile data from Firestore.
     */
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    /**
     * Verification for specific leadership roles.
     */
    function hasRole(role) {
      return isSignedIn() && getUserData().role == role;
    }

    /**
     * Comprehensive check for Executive (President or Admin) access.
     * Strictly relies on the database role. No email backdoors.
     */
    function isExecutive() {
      if (!isSignedIn()) return false;
      let userRole = getUserData().role;
      return userRole == 'President' || userRole == 'Admin' || userRole == 'System Admin';
    }

    // ==========================================
    // COLLECTION RULES
    // ==========================================

    /**
     * Member Registry: Protects sensitive personal information.
     */
    match /users/{userId} {
      // Read: Users can read their own profile. Executives can read all for directory/management.
      allow read: if isSignedIn() && (isOwner(userId) || isExecutive());
      
      // Create: Allow initial registration.
      allow create: if isSignedIn();
      
      // Update: Users can update their bio/photo but CANNOT change their role or status.
      // Executives have full update authority.
      allow update: if isExecutive() || (
        isOwner(userId) && 
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'isApproved', 'isAuthorized', 'isSuperAdmin'])
      );
      
      // Delete: Strictly restricted to President/Admin.
      allow delete: if isExecutive();
    }

    /**
     * Calendar Activities: The operational heartbeat of the movement.
     */
    match /calendar_activities/{activityId} {
      // Read: Public view restricted to authorized events. Executives see drafts for audit.
      allow read: if isSignedIn() && (resource.data.isAuthorized == true || isExecutive());
      
      // Create: Restricted to Secretary General, Admin, and President.
      allow create: if isSignedIn() && (
        getUserData().role in ['Secretary General', 'Admin', 'President']
      );
      
      // Update: Strictly restrict authorization (flipping isAuthorized) to the President ONLY.
      allow update: if hasRole('President');
      
      // Delete: Executives only.
      allow delete: if isExecutive();
    }

    /**
     * Secure Document Vault: Tiered distribution of intelligence and materials.
     */
    match /vault/{docId} {
      allow read: if isSignedIn() && (
        isExecutive() || 
        resource.data.targetAudience.contains('All Members') || 
        resource.data.targetAudience.contains(getUserData().role)
      );
      allow write: if isExecutive();
    }

    /**
     * Attendance & QR Scanning: Secure check-in data.
     */
    match /attendance/{attendanceId} {
      allow read, write: if isExecutive();
    }

    /**
     * Communication & System Audits: SMS logs and executive history.
     */
    match /communication_audit/{auditId} {
      allow read, write: if isExecutive();
    }

    /**
     * Meeting Agendas: Virtual briefing metadata.
     */
    match /meeting_agendas/{agendaId} {
      allow read: if isSignedIn() && (
        isExecutive() || 
        resource.data.targetAudience.contains('All Members') || 
        resource.data.targetAudience.contains(getUserData().role)
      );
      allow write: if isExecutive();
    }

    /**
     * Community Feedback: Communication between grassroots and leadership.
     */
    match /community_feedback/{feedbackId} {
      allow read: if isExecutive() || (isSignedIn() && resource.data.submitterUid == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.submitterUid == request.auth.uid;
      allow update, delete: if isExecutive();
    }

    /**
     * Announcements, Polls, and Campaign Actions.
     */
    match /announcements/{id} {
      allow read: if isSignedIn();
      allow write: if isExecutive();
    }

    match /polls/{id} {
      allow read: if isSignedIn();
      allow update: if isSignedIn(); // Voting logic
      allow write: if isExecutive();
    }

    match /campaign_actions/{id} {
      allow read: if isSignedIn();
      allow update: if isSignedIn(); // Signing logic
      allow write: if isExecutive();
    }
  }
}
