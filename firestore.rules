
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isPrivilegedEmail() {
      let email = request.auth.token.email.lower();
      return email == 'iamgrecobelgica@gmail.com' || 
             email == 'j.burns372@gmail.com' || 
             email == 'j.burns2372@gmail.com' || 
             email == 'j.burns.2372@gmail.com' || 
             email == 'mariashellajoygomez@gmail.com';
    }

    function isAdministrator() {
      if (!isSignedIn()) return false;
      if (isPrivilegedEmail()) return true;
      
      let userPath = /databases/$(database)/documents/users/$(request.auth.uid);
      let leadershipRoles = [
        'President', 'Chairman', 'Vice Chairman', 'VP', 'Secretary General',
        'Treasurer', 'Auditor', 'VP Ways & Means Chair', 'VP Media Comms',
        'VP Soc Med Comms', 'VP Events and Programs', 'VP Membership',
        'VP legal affairs', 'Admin', 'System Admin'
      ];
      return exists(userPath) && get(userPath).data.role in leadershipRoles;
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isOwner(userId) || isAdministrator() || (isSignedIn() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['recruitCount']));
      allow delete: if isAdministrator();
    }

    match /campaign_actions/{actionId} {
      allow read: if isSignedIn();
      allow update: if isSignedIn() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['signedBy']);
      allow write: if isAdministrator();
    }

    match /polls/{pollId} {
      allow read: if isSignedIn();
      allow update: if isSignedIn() && 
                    !resource.data.votedBy.contains(request.auth.uid) &&
                    request.resource.data.votedBy.contains(request.auth.uid);
      allow write: if isAdministrator();
    }

    match /community_feedback/{feedbackId} {
      allow read: if isSignedIn() && (resource.data.submitterUid == request.auth.uid || isAdministrator());
      allow create: if isSignedIn() && request.resource.data.submitterUid == request.auth.uid;
      allow update, delete: if isAdministrator();
    }
  }
}
