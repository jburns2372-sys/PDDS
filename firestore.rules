
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ==========================================
    // GLOBAL HELPERS
    // ==========================================

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasRole(role) {
      return isSignedIn() && getUserData().role == role;
    }

    function isExecutive() {
      if (!isSignedIn()) return false;
      let userData = getUserData();
      let userRole = userData.role;
      let isAdmin = userData.get('isAdmin', false);
      return userRole == 'President' || userRole == 'Admin' || userRole == 'System Admin' || isAdmin == true;
    }

    function isSecGen() {
      return hasRole('Secretary General') || hasRole('Admin') || hasRole('System Admin');
    }

    function isPRO() {
      return hasRole('Public Relations Officer') || isExecutive();
    }

    function isTreasurer() {
      return hasRole('Treasurer') || isExecutive();
    }

    function isCoordinator() {
      return hasRole('Coordinator') || isExecutive();
    }

    // ==========================================
    // COLLECTION RULES
    // ==========================================

    match /users/{userId} {
      allow read: if isSignedIn() && (isOwner(userId) || isExecutive() || isSecGen());
      allow create: if isSignedIn();
      
      allow update: if isExecutive() || isSecGen() || (
        isOwner(userId) && 
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'isApproved', 'isAuthorized', 'isSuperAdmin', 'isAdmin', 'isVerified', 'adminNotes', 'vettingLevel', 'idVerificationUrl'])
      );
      
      allow delete: if isExecutive();
    }

    match /announcements/{id} {
      allow read: if isSignedIn();
      allow write: if isPRO();
    }

    match /chat_rooms/{roomId} {
      allow read: if isSignedIn();
      allow write: if isExecutive();

      match /messages/{msgId} {
        allow read: if isSignedIn() && (
          roomId == 'National' || 
          getUserData().city == roomId || 
          isExecutive()
        );

        allow create: if isSignedIn() && 
          getUserData().isVerified == true && 
          (roomId == 'National' || getUserData().city == roomId) &&
          request.resource.data.senderUid == request.auth.uid;

        allow delete: if isSignedIn() && (
          isExecutive() || 
          (hasRole('Coordinator') && getUserData().city == roomId)
        );

        allow update: if isSignedIn() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isReported']);
      }
    }

    match /calendar_activities/{activityId} {
      allow read: if isSignedIn() && (resource.data.isAuthorized == true || isExecutive());
      allow create: if isSignedIn() && (
        getUserData().role in ['Secretary General', 'Admin', 'President', 'Coordinator'] || isPRO()
      );
      allow update: if hasRole('President') || isExecutive();
      allow delete: if isExecutive();
    }

    match /logistics_logs/{logId} {
      allow read: if isSignedIn() && (isTreasurer() || isExecutive());
      allow write: if isTreasurer() || isExecutive();
    }

    match /meeting_requests/{id} {
      allow read: if isSignedIn() && (
        resource.data.hostUid == request.auth.uid || 
        isExecutive() || 
        (hasRole('Coordinator') && getUserData().city == resource.data.city) ||
        resource.data.status == 'Approved'
      );
      allow create: if isSignedIn() && getUserData().vettingLevel in ['Silver', 'Gold'];
      allow update: if isSignedIn() && (
        (hasRole('Coordinator') && getUserData().city == resource.data.city) || 
        isExecutive()
      );
      allow delete: if isExecutive() || (hasRole('Coordinator') && getUserData().city == resource.data.city);
    }

    match /polls/{id} {
      allow read: if isSignedIn();
      allow update: if isSignedIn() && 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['votes', 'votedBy']) &&
        !resource.data.votedBy.contains(request.auth.uid) &&
        request.resource.data.votedBy.contains(request.auth.uid);
      allow write: if isPRO() || isExecutive();
    }
  }
}
